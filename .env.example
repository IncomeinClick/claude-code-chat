# === Authentication ===
# Generate a secret: npm run gen-secret
JWT_SECRET=

# Login username (email, name, anything you want)
USERNAME=

# Hash your password: npm run hash-password YOUR_PASSWORD
PASSWORD_HASH=

# === Server ===
PORT=3456
BIND_HOST=127.0.0.1

# === Claude Code ===
# Path to claude binary (default: claude, uses PATH)
CLAUDE_BIN=claude

# Working directory for Claude sessions (default: $HOME)
CLAUDE_CWD=

# === Display ===
# Name shown in the UI (default: Claude Code)
DISPLAY_NAME=Claude Code

# === Session ===
# Inactivity timeout in seconds (default: 1800 = 30 min)
INACTIVITY_TIMEOUT=1800
